// Place your key bindings in this file to override the defaults
[
    {
        "args": {
            "commands": [
                "chatgpt.addToThread",
                "chatgpt.sidebarView.focus"
            ]
        },
        "command": "runCommands",
        "key": "ctrl+l",
        "when": "chatgpt.sidebarView.visible || chatgpt.sidebarSecondaryView.visible"
    },
    {
        "command": "claude-vscode.focus",
        "key": "ctrl+l",
        "when": "claude-vscode.sideBarActive || activeWebviewPanelId == 'claudeVSCodePanel'"
    },
    {
        "command": "clangd.switchheadersource",
        "key": "f4",
        "when": "editorTextFocus && resourceLangId == 'c' || editorTextFocus && resourceLangId == 'cpp' || editorTextFocus && resourceLangId == 'cuda-cpp' || editorTextFocus && resourceLangId == 'objective-c' || editorTextFocus && resourceLangId == 'objective-cpp'"
    }
]
